; =============================================================================
; WHAT HE ACTUALLY BUYS
; =============================================================================

; --- FOOD ---
; Cooked mutant meat: the cook's primary ingredient — best buy rate
food_zone             = 1.0, 0.85
; Packaged and preserved food: restocking the pantry
food_packaged           = 0.80, 0.65

; --- DRINKS ---
; Basic drinks: water and non-alcoholic — always needed
drink_basic             = 0.85, 0.70
; Alcohol: the bar's core product — buys well to restock
