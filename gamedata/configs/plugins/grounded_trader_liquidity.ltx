; GROUNDED - Trader Liquidity Config
;
; bracket_min    trader drifts positive when funds fall below this
; bracket_max    trader drifts negative when funds rise above this
; drift_median   typical daily shift magnitude in rubles
; drift_variance randomness applied to drift magnitude (0.5 = +-50%)
; init_min       starting funds on first ever visit (one-time)
; init_max       starting funds on first ever visit (one-time)
; reserve_threshold  funds level below which trader starts lowering their offers

[default]
bracket_min    = 30000
bracket_max    = 60000
drift_median   = 5000
drift_variance = 0.6
init_min       = 40000
init_max       = 50000
reserve_threshold = 10000

