#include "presets\trade_discounts.ltx"
#include "presets\trade_presets.ltx"

[trader]
buy_condition = trade_generic_buy
sell_condition = trade_generic_sell
buy_supplies = supplies_1
buy_item_condition_factor = 0.30
buy_item_exponent = 2.25
sell_item_exponent = 0.8

sell_item_min_condition = 0.3
sell_item_max_condition = 0.98

discounts = discount_barman

[trade_generic_buy]:barman

[trade_generic_sell]:barman

[supplies_1]:common_stock
; The bar. One tier, always open, never quite the same twice.
; Water, drinks, cigarettes, food — the basics of stalker camp life.
; The cook handles mutant meat. Basic first aid lives behind the counter.
; No weapons, no gear, no zone items. Just what a bar stocks.

