#include "presets\trade_discounts.ltx"
#include "presets\trade_presets.ltx"

;EDITED GROUNDED TRADER OVERHAUL

[trader]
buy_condition =  trade_generic_buy
sell_condition = trade_generic_sell
buy_supplies = {=actor_goodwill_ge(killer:1000)} supplies_5, {=heavy_pockets_functor()} supplies_5, {=actor_goodwill_ge(killer:800)} supplies_4, {=actor_goodwill_ge(killer:600)} supplies_3, {=actor_goodwill_ge(killer:400)} supplies_2,  supplies_1
buy_item_condition_factor = 0.60		;0.40
buy_item_exponent = 2.8
sell_item_exponent = 1.2

sell_item_min_condition = 0.6
sell_item_max_condition = 0.98

discounts = discount_killer

;how much the grounded_trader_multipliers influence the item costs (0 to 1)
sell_mult_influence = 0.5
buy_mult_influence = 1

[trade_generic_buy]:merchant

[trade_generic_sell]:merchant


