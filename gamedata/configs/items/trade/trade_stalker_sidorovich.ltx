;EDITED GROUNDED TRADER OVERHAUL

[trader]
buy_condition =  trade_generic_buy
sell_condition = trade_generic_sell
buy_supplies = {=actor_goodwill_ge(stalker:1000)} supplies_5, {=heavy_pockets_functor()} supplies_5, {=actor_goodwill_ge(stalker:800)} supplies_4, {=actor_goodwill_ge(stalker:600)} supplies_3, {=actor_goodwill_ge(stalker:400)} supplies_2,  supplies_1
buy_item_condition_factor = 0.3		;0.40
buy_item_exponent = 2.0
sell_item_exponent = 1.2

discounts = discount_sid

sell_item_min_condition = 0.3
sell_item_max_condition = 0.98

[trade_generic_buy]:trasher
isg_patch = 3,3
greh_patch = 3,3

[trade_generic_sell]:trasher

