#include "presets\trade_discounts.ltx"
#include "presets\trade_presets.ltx"

;EDITED GROUNDED TRADER OVERHAUL

[trader]
buy_condition =  trade_generic_buy
sell_condition = trade_generic_sell
buy_supplies = {=actor_goodwill_ge(csky:1000)} supplies_5, {=heavy_pockets_functor()} supplies_5, {=actor_goodwill_ge(csky:800)} supplies_4, {=actor_goodwill_ge(csky:600)} supplies_3, {=actor_goodwill_ge(csky:400)} supplies_2,  supplies_1
buy_item_condition_factor = 0.30
buy_item_exponent = 2.25
sell_item_exponent = 1.1

sell_item_min_condition = 0.4
sell_item_max_condition = 0.98

;how much the grounded_trader_multipliers influence the item costs (0 to 1)
sell_mult_influence = 0.5
buy_mult_influence = 1

discounts = discount_csky

[trade_generic_buy]:supplier

[trade_generic_sell]:supplier


