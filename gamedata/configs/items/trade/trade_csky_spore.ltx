;EDITED GROUNDED TRADER OVERHAUL

[trader]
buy_condition =  trade_generic_buy
sell_condition = trade_generic_sell
buy_supplies = {=actor_goodwill_ge(csky:1000)} supplies_5, {=heavy_pockets_functor()} supplies_5, {=actor_goodwill_ge(csky:800)} supplies_4, {=actor_goodwill_ge(csky:600)} supplies_3, {=actor_goodwill_ge(csky:400)} supplies_2,  supplies_1
