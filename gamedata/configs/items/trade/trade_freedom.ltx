;EDITED GROUNDED TRADER OVERHAUL

[trader]
buy_condition =  trade_generic_buy
sell_condition = trade_generic_sell
buy_supplies = {=actor_goodwill_ge(freedom:1000)} supplies_5, {=heavy_pockets_functor()} supplies_5, {=actor_goodwill_ge(freedom:800)} supplies_4, {=actor_goodwill_ge(freedom:600)} supplies_3, {=actor_goodwill_ge(freedom:400)} supplies_2,  supplies_1
buy_item_condition_factor = 0.40
buy_item_exponent = 2.5
sell_item_exponent = 1.4

sell_item_min_condition = 0.5
sell_item_max_condition = 0.98

discounts = discount_freedom

[trade_generic_buy]:trasher
itm_drugkit           = 5.0,5.0

[trade_generic_sell]:trasher


