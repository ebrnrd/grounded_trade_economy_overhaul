#include "presets\trade_discounts.ltx"
#include "presets\trade_presets.ltx"

;EDITED GROUNDED TRADER OVERHAUL

[trader]
buy_condition =  trade_generic_buy
sell_condition = trade_generic_sell
buy_supplies = {=actor_goodwill_ge(bandit:1000)} supplies_5, {=heavy_pockets_functor()} supplies_5, {=actor_goodwill_ge(bandit:800)} supplies_4, {=actor_goodwill_ge(bandit:600)} supplies_3, {=actor_goodwill_ge(bandit:400)} supplies_2,  supplies_1
buy_item_condition_factor = 0.20		;0.40
buy_item_exponent = 2.4
sell_item_exponent = 1.3

sell_item_min_condition = 0.2
sell_item_max_condition = 0.9

discounts = discount_bandit

;how much the grounded_trader_multipliers influence the item costs (0 to 1)
sell_mult_influence = 0.5
buy_mult_influence = 1

[trade_generic_buy]:trasher

[trade_generic_sell]:trasher

