[trader]
buy_condition =  trade_generic_buy
sell_condition = trade_generic_sell
buy_supplies = {=actor_goodwill_ge(ecolog:1000)} supplies_5, {=heavy_pockets_functor()} supplies_5, {=actor_goodwill_ge(ecolog:800)} supplies_4, {=actor_goodwill_ge(ecolog:600)} supplies_3, {=actor_goodwill_ge(ecolog:400)} supplies_2,  supplies_1
