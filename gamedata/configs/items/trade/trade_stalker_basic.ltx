;EDITED GROUNDED TRADER OVERHAUL

[trader]
buy_condition =  trade_generic_buy
sell_condition = trade_generic_sell
buy_supplies = {=actor_goodwill_ge(stalker:700)} supplies_3, {=heavy_pockets_functor()} supplies_3, {=actor_goodwill_ge(stalker:400)} supplies_2,  supplies_1
buy_item_condition_factor = 0.2		;0.40
buy_item_exponent = 2.25
sell_item_exponent = 0.8

sell_item_min_condition = 0.2
sell_item_max_condition = 0.95

discounts = discount_stalker

[trade_generic_buy]:trasher
isg_patch = 3,3
greh_patch = 3,3

[trade_generic_sell]:trasher

