#include "presets\trade_discounts.ltx"
#include "presets\trade_presets.ltx"

[trader]
buy_condition =  trade_generic_buy
sell_condition = trade_generic_sell
buy_supplies = {=actor_goodwill_ge(army:2000)} supplies_5, {=heavy_pockets_functor()} supplies_5, {=actor_goodwill_ge(army:1500)} supplies_4, {=actor_goodwill_ge(army:1000)} supplies_3, {=actor_goodwill_ge(army:500)} supplies_2,  supplies_1
buy_item_condition_factor = 0.50		;0.40
buy_item_exponent = 2.6
sell_item_exponent = 0.8

discounts = discount_military_trader

sell_item_min_condition = 0.6
sell_item_max_condition = 0.98

[trade_generic_buy]:merchant

[trade_generic_sell]:merchant

