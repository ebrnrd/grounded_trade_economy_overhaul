--[[
	GROUNDED - Layer 3: Dynamic Discounts

	Traders periodically run market events that temporarily boost prices
	for specific item categories. Events fire independently for sell and buy
	directions. When an event fires the player is notified via PDA.

	This module exposes one function to the liquidity script:
		grounded_trade_discounts.get_discount_multiplier(npc_id, item_section, mode)
		  mode 1 = player selling to trader (we want multiplier > 1.0)
		  mode 2 = player buying from trader (we want multiplier < 1.0)
		  returns a float multiplier applied on top of all other calculations
		  returns 1.0 if no active discount for this item/mode

	Event lifecycle:
	- Each trader has independent sell and buy event timers
	- On timer expiry a new event fires: 1-3 random eligible categories
	  are selected and assigned a random discount percentage
	- Events last a random number of in-game days
	- First event for each trader fires after a 1-day delay
	- PDA notification sent when event fires (if discount crosses threshold)

	Config: gamedata/configs/plugins/grounded_trade_discounts.ltx
	Items:  gamedata/configs/plugins/grounded_discount_item_groups.ltx
--]]

local gt              = game.translate_string
local ctime_to_t      = utils_data.CTime_to_table
local t_to_ctime      = utils_data.CTime_from_table

local cur_npc_id

-- these are read once and cached; on_option_change refreshes them
local MIN_EVENT_DURATION  = nil  -- in-game days
local MAX_EVENT_DURATION  = nil
local MIN_DISCOUNT        = nil  -- percent
local MAX_DISCOUNT        = nil
local MAX_CATS            = nil  -- max categories per event (1-3)
local MSG_THRESHOLD       = nil  -- minimum % to trigger PDA notification

local function refresh_config()
	MIN_EVENT_DURATION = grounded_trade_mcm.get_config("min_event_duration")
	MAX_EVENT_DURATION = grounded_trade_mcm.get_config("max_event_duration")
	MIN_DISCOUNT       = grounded_trade_mcm.get_config("min_discount")
	MAX_DISCOUNT       = grounded_trade_mcm.get_config("max_discount")
	MAX_CATS           = grounded_trade_mcm.get_config("max_categories")
	MSG_THRESHOLD      = grounded_trade_mcm.get_config("msg_threshold")
end

function on_option_change()
	refresh_config()
end

---------------- item groups ----------------
-- maps item section -> group string (e.g. "xt_weapons", "arts_3")
-- built once on first update via categorize_items()
local item_to_group = {}

local VANILLA_CATEGORIES = {
	["Items (Drink)"]    = "supplies_all",
	["Items (Tool)"]     = "supplies_all",
	["Items (Medical)"]  = "meds_all",
	["Items (Repair)"]   = "repair_all",
	["Items (Parts)"]    = "parts_all",
	["Weapons (Ammo)"]   = "ammo_all",
	["Weapons (Melee)"]  = "wpn_all",
	["Weapons (Pistol)"] = "wpn_all",
	["Weapons (Shotgun)"]= "wpn_all",
	["Weapons (SMG)"]    = "wpn_all",
	["Weapons (Rifle)"]  = "wpn_all",
	["Weapons (Sniper)"] = "wpn_all",
	["Helmets"]          = "outfit_all",
	["Outfits (Light)"]  = "outfit_all",
	["Outfits (Medium)"] = "outfit_all",
	["Outfits (Heavy)"]  = "outfit_all",
}

local function categorize_items()
	-- vanilla categories via debug spawn table
	for dbg_name, group in pairs(VANILLA_CATEGORIES) do
		local ar = ui_debug_main.get_spawn_table(dbg_name)
		if ar then
			for i = 1, #ar do
				item_to_group[ar[i]] = group
			end
		end
	end

	-- additional categories from LTX
	-- format: each section name is the group, each key is an item section
	local ltx = ini_file("plugins\\grounded_discount_item_groups.ltx")
	if not ltx then return end
	ltx:section_for_each(function(sec)
		local n = ltx:line_count(sec)
		for i = 0, n - 1 do
			local _, id, _ = ltx:r_line_ex(sec, i, "", "")
			if id and id ~= "" then
				item_to_group[id] = sec
			end
		end
	end)
end

